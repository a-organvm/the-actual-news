{
  "name": "the-actual-news",
  "private": true,
  "version": "0.0.0",
  "description": "Verifiable news ledger platform — news as a public service",
  "license": "AGPL-3.0-only",
  "scripts": {
    "build": "pnpm -r build",
    "cloudflare:build": "pnpm --filter public-web cloudflare:build",
    "cloudflare:deploy": "pnpm --filter public-web cloudflare:deploy",
    "cloudflare:preview": "pnpm --filter public-web cloudflare:preview",
    "cloudflare:smoke": "PUBLIC_WEB_BASE_URL=https://the-actual-news-public.ivixivi.workers.dev pnpm smoke:public",
    "container:check": "node tools/containers/validate-boundaries.mjs",
    "domain:doctor": "node tools/public-web/domain-doctor.mjs",
    "dev": "pnpm -r --parallel dev",
    "env:check": "node tools/env/validate-boundaries.mjs",
    "launch:check": "pnpm env:check && node tools/public-web/launch-check.mjs",
    "launch:check:strict": "pnpm env:check && node tools/public-web/launch-check.mjs --strict",
    "launch:conversions": "node tools/public-web/conversion-smoke.mjs",
    "launch:deployed": "node tools/public-web/deployed-launch-gate.mjs",
    "launch:local": "node tools/public-web/local-launch-gate.mjs",
    "launch:report": "node tools/public-web/write-launch-report.mjs",
    "launch:smoke": "node tools/public-web/launch-smoke.mjs",
    "public-env:template": "node tools/public-web/print-public-env-template.mjs",
    "public-source:check": "node tools/public-web/source-boundary-check.mjs",
    "lint": "pnpm -r lint",
    "smoke:public": "pnpm --filter public-web smoke",
    "conformance:doctor": "node tools/conformance/doctor.mjs",
    "conformance:test": "pnpm --filter conformance-harness test",
    "test": "pnpm -r test",
    "test:services": "pnpm --filter claim-service test && pnpm --filter evidence-service test && pnpm --filter gateway-service test && pnpm --filter story-service test && pnpm --filter verify-service test",
    "typecheck": "pnpm -r typecheck"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
